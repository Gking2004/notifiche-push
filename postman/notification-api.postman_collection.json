{
  "info": {
    "_postman_id": "notification-api-collection",
    "name": "Notification API",
    "description": "Tutte le chiamate API del progetto Notification (porta 8082)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8082",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Endpoint per la gestione dell'autenticazione (/auth)",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Registra un nuovo utente su Keycloak e nel database locale. Restituisce le informazioni dell'utente con il token di accesso."
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Esegue il login di un utente tramite Keycloak. Restituisce il token di accesso."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "description": "Endpoint per la gestione degli utenti (/users)",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            },
            "description": "Recupera la lista di tutti gli utenti registrati."
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["users", "1"]
            },
            "description": "Recupera un utente tramite il suo ID primario."
          },
          "response": []
        },
        {
          "name": "Get User by Username",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/username/testuser",
              "host": ["{{baseUrl}}"],
              "path": ["users", "username", "testuser"]
            },
            "description": "Recupera un utente tramite il suo username."
          },
          "response": []
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["users", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser_updated\",\n  \"email\": \"testuser_updated@example.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Aggiorna un utente esistente tramite il suo ID primario."
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["users", "1"]
            },
            "description": "Elimina un utente dal database locale."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Notifications",
      "description": "Endpoint per la gestione delle notifiche (/api/notification)",
      "item": [
        {
          "name": "Create Notification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notification/create",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notification", "create"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Richiesta ferie\",\n  \"body\": \"Giovanni Rossi ha richiesto ferie dal 01/01/2025 al 10/01/2025\",\n  \"type\": \"VACATION_REQUEST\",\n  \"payload\": {\n    \"startDate\": \"2025-01-01\",\n    \"endDate\": \"2025-01-10\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Crea una nuova notifica. Restituisce la notifica creata."
          },
          "response": []
        },
        {
          "name": "Get Notification by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/notification/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notification", "1"]
            },
            "description": "Recupera una notifica tramite il suo ID."
          },
          "response": []
        }
      ]
    },
