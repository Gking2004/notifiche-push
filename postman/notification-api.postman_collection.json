            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user-123\",\n  \"token\": \"fcm-token-example\",\n  \"platform\": \"ANDROID\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Registra un nuovo device. Restituisce il device creato."
          },
          "response": []
        },
        {
          "name": "Get Device by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/devices/1",
              "host": ["{{baseUrl}}"],
              "path": ["devices", "1"]
            },
            "description": "Recupera un device tramite il suo ID."
          },
          "response": []
        },
        {
          "name": "Update Device",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/devices/1",
              "host": ["{{baseUrl}}"],
              "path": ["devices", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user-123\",\n  \"token\": \"fcm-token-updated\",\n  \"platform\": \"IOS\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Aggiorna un device esistente tramite il suo ID."
          },
          "response": []
        },
        {
          "name": "Delete Device",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/devices/1",
              "host": ["{{baseUrl}}"],
              "path": ["devices", "1"]
            },
            "description": "Elimina un device tramite il suo ID."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Device Notifications",
      "description": "Endpoint per inviare notifiche ai device via FCM (/device-notifications)",
      "item": [
        {
          "name": "Send Device Notification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/device-notifications/send",
              "host": ["{{baseUrl}}"],
              "path": ["device-notifications", "send"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notificationId\": 1,\n  \"deviceToken\": \"fcm-token-example\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Invia una notifica ad un device tramite FCM. Richiede l'ID della notifica e il token FCM del device."
          },
          "response": []
        },
        {
          "name": "Get Device Notification by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/device-notifications/1",
              "host": ["{{baseUrl}}"],
              "path": ["device-notifications", "1"]
            },
            "description": "Recupera una device-notification tramite il suo ID."
          },
          "response": []
        }
